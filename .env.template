# ============================================================
# Construction API — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ============================================================

# Application
NODE_ENV=development
PORT=3000

# Zoho Inventory
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.in
ZOHO_ORG_ID=

# Firebase Admin SDK
# Value can be either:
#   a) A JSON string:     FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
#   b) An absolute path:  FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-sa.json
FIREBASE_SERVICE_ACCOUNT=

# Admin Portal
# ADMIN_PASSWORD must be at least 8 characters
# ADMIN_TOKEN must be at least 16 characters
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Google Maps (optional — used for geocoding and ETA)
GOOGLE_MAPS_API_KEY=
WAREHOUSE_LAT=12.863326
WAREHOUSE_LNG=80.226196

# Cloudinary (optional — used for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Upstash Redis (optional — omit to disable distributed cache)
# Create a free database at console.upstash.com, region ap-south-1 (Mumbai)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Grafana Cloud OTLP (optional — omit to send to local Jaeger/Collector on port 4318)
GRAFANA_USER=
GRAFANA_API_KEY=
OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
